generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FanData {
  id               Int      @id @default(autoincrement())
  No               Int?
  Model            String?
  AFS              Int?     @map("AF-S")
  AFL              Int?     @map("AF-L")
  WF               Int?
  ARTF             Int?
  SF               Int?
  ABSFC            Int?     @map("ABSF-C")
  ABSFS            Int?     @map("ABSF-S")
  SABF             Int?
  SARTF            Int?
  AJF              Int?
  bladesSymbol     String
  bladesMaterial   String
  noBlades         Int
  bladesAngle      Float
  hubType          Int
  impellerConf     String
  impellerInnerDia Float
  desigDensity     Float
  RPM              Float
  airFlow          String
  totPressure      String
  velPressure      String
  staticPressure   String
  fanInputPow      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("fan_data")
}

model MotorData {
  id                         Int      @id @default(autoincrement())
  material                   String?
  model                      String?
  powerKW                    Float?
  speedRPM                   Float?
  noOfPoles                  Int?
  ratedCurrentIn             Float?
  ratedTorqueMn              Float?
  lockedRotorCurrentDOL      Float?
  iaPerInDOL                 Float?
  lockedRotorTorqueDOL       Float?
  maPerMnDOL                 Float?
  lockedRotorCurrentYD       Float?
  iaPerInYD                  Float?
  lockedRotorTorqueYD        Float?
  maPerMnYD                  Float?
  powerFactorCos             Float?
  phase                      String?
  frameSize                  String?
  shaftDiameter              Float?
  shaftLength                Float?
  shaftFeatherKeyLength      Float?
  ie                         String?
  frontBearing               String?
  rearBearing                String?
  noiseLevel                 Float?
  weight                     Float?
  efficiency50Hz             Float?
  efficiency37_5Hz           Float?
  efficiency25Hz             Float?
  runCapacitor               Float?
  startCapacitor             Float?
  NoCapacitors               Int?
  NoPhases                   Int?
  insClass                   String?
  b3PriceWithoutVat          Float?
  b3PriceWithVat             Float?
  otherPriceWithoutVat       Float?
  otherPriceWithVat          Float?
  cableCurrent               Float?
  cableSize                  String?
  cablePriceWithVat          Float?
  cableLugsNo                Int?
  cableLugsUPWithoutVat      Float?
  cableLugsUPWithVat         Float?
  cableLugsTPWithVat         Float?
  cableHeatShrinkNo          Float?
  cableHeatShrinkUPWithoutVat Float?
  cableHeatShrinkUPWithVat   Float?
  cableHeatShrinkTPWithVat   Float?
  flexibleConnectorMeter     Float?
  flexibleConnectorSize      String?
  flexibleConnectorUPWithVat Float?
  flexibleConnectorTPWithVat Float?
  glandNo                    Float?
  glandUPWithVat             Float?
  glandTPWithVat             Float?
  brassBarNo                 Float?
  brassBarUPWithVat          Float?
  brassBarTPWithVat          Float?
  electricalBoxSize          String?
  electricalBoxUPWithVat     Float?
  totalPriceWithVat          Float?
  powerHorse                 Float?
  netpower                   Float?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@map("motor_data")
}

model PricingCategory {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  displayName String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       PricingItem[]

  @@map("pricing_categories")
}

model PricingItem {
  id              Int             @id @default(autoincrement())
  categoryId      Int
  sr              Int
  description     String
  unit            String
  updatedDate     String?
  priceWithoutVat Float?
  priceWithVat    Float?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  category        PricingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("pricing_items")
}

model PricingLog {
  id         Int      @id @default(autoincrement())
  adminId    Int
  action     String
  categoryId Int?
  itemId     Int?
  details    String?
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  @@map("pricing_logs")
}

model AccessoryPricing {
  id                       Int      @id @default(autoincrement())
  sr                       Int
  fanModel                 String
  fanSizeMm                Int
  vinylStickersLe          Float?
  namePlateLe              Float?
  packingLe                Float?
  labourCostLe             Float?
  internalTransportationLe Float?
  boltsAndNutsKg           Float?
  priceWithVatLe           Float?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("accessory_pricing")
}

model AxialImpellerBlade {
  id                   Int      @id @default(autoincrement())
  symbol               String
  material             String
  bladeType            String
  lengthMm             Float
  bladeWeightKg        Float
  moldCostWithVat      Float
  machiningCostWithVat Float
  transportationCost   Float
  packingCost          Float
  steelBallsCost       Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  bladeFactor          Float?

  @@map("axial_impeller_blades")
}

model AxialImpellerHub {
  id                   Int      @id @default(autoincrement())
  symbol               String
  material             String
  hubType              String
  sizeMm               Float
  hubWeightKg          Float
  moldCostWithVat      Float
  machiningCostWithVat Float
  transportationCost   Float
  packingCost          Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("axial_impeller_hubs")
}

model AxialImpellerFrame {
  id                   Int      @id @default(autoincrement())
  material             String
  frameSizeMm          Float
  sizeMm               Float
  weightKg             Float
  moldCostWithVat      Float
  machiningCostWithVat Float
  transportationCost   Float
  packingCost          Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("axial_impeller_frames")
}

model AxialCasingPricing {
  id                         Int      @id @default(autoincrement())
  model                      String
  sizeMm                     Float
  casingWeightKgWithoutScrap Float
  scrapPercentage            Float
  casingCircumferenceMeter   Float?
  laserTimeMinutes           Float?
  bendingLine                Float?
  rolling                    Float?
  paintingDiameter           Float?
  profitPercentage           Float?
  accessory1Description      String?
  accessory1PriceWithoutVat  Float?
  accessory2Description      String?
  accessory2PriceWithoutVat  Float?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([model, sizeMm], name: "unique_model_size")
  @@map("axial_casing_pricing")
}

model CentrifugalFanData {
  id               Int      @id @default(autoincrement())
  bladesType       String?
  bladesModel      String?
  minSpeedRPM      Int?
  highSpeedRPM     Int?
  impellerType     String?
  fanShaftDiameter Float?
  innerDiameter    Float?
  desigDensity     Float?
  RPM              Float?
  airFlow          String
  totPressure      String
  velPressure      String
  staticPressure   String
  fanInputPow      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("centrifugal_fan_data")
}

model CentrifugalMotorData {
  id           Int      @id @default(autoincrement())
  material     String?
  model        String?
  powerKW      Float?
  speedRPM     Float?
  NoPoles      Int?
  rated        String?
  DOL          String?
  starDelta    String?
  powerFactor  Float?
  Phase        Int?
  frameSize    Int?
  shaftDia     Float?
  shaftLength  Float?
  shaftFeather Float?
  IE           Int?
  frontBear    String?
  rearBear     String?
  noiseLvl     Int?
  weightKg     Float?
  effCurve     String?
  NoCapacitors Int?
  NoPhases     Int?
  insClass     String?
  powerHorse   Float?
  netpower     Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("centrifugal_motor_data")
}

model CentrifugalCasingPricing {
  id              Int                               @id @default(autoincrement())
  type            String
  model           String
  sizeMm          Float
  modelAndSize    String                            @unique
  createdAt       DateTime                          @default(now())
  updatedAt       DateTime                          @updatedAt
  accessories     CentrifugalCasingAccessories?
  bearingAssembly CentrifugalCasingBearingAssembly?
  beltCover       CentrifugalCasingBeltCover?
  fanBase         CentrifugalCasingFanBase?
  frame           CentrifugalCasingFrame?
  funnels         CentrifugalCasingFunnels?
  impeller        CentrifugalCasingImpeller?
  matchingFlange  CentrifugalCasingMatchingFlange?
  motorBase       CentrifugalCasingMotorBase?
  sleeveShaft     CentrifugalCasingSleeveShaft?
  volute          CentrifugalCasingVolute?

  @@map("centrifugal_casing_pricing")
}

model CentrifugalCasingVolute {
  id                              Int                      @id @default(autoincrement())
  casingId                        Int                      @unique
  volute2mmWeightKgWithoutScrap   Float?
  volute2mmScrapPct               Float?
  volute2mmWeightKgWithScrap      Float?
  volute2mmSheetMetalDimensionsMm String?
  volute1mmWeightKgWithoutScrap   Float?
  volute1mmScrapPct               Float?
  volute1mmWeightKgWithScrap      Float?
  volute1mmSheetMetalDimensionsMm String?
  volute1mmLaserTimeMin           Float?
  volute1mmRolling                Float?
  volute1mmSheetMetalOverlapping  Float?
  createdAt                       DateTime                 @default(now())
  updatedAt                       DateTime                 @updatedAt
  casing                          CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_volute")
}

model CentrifugalCasingFrame {
  id                            Int                      @id @default(autoincrement())
  casingId                      Int                      @unique
  angleBarWeightKgWithoutScrap  Float?
  angleBarScrapPct              Float?
  angleBarWeightKgWithScrap     Float?
  angleBarDimensionsMm          String?
  supportWeightKgWithoutScrap   Float?
  supportScrapPct               Float?
  supportWeightKgWithScrap      Float?
  supportSheetMetalDimensionsMm String?
  supportLaserTimeMin           Float?
  supportCasingCircumferenceM   Float?
  supportPaintingLe             Float?
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt
  casing                        CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_frame")
}

model CentrifugalCasingImpeller {
  id                                 Int                      @id @default(autoincrement())
  casingId                           Int                      @unique
  bladesWeightKgWithoutScrap         Float?
  bladesScrapPct                     Float?
  bladesWeightKgWithScrap            Float?
  bladesSheetMetalDimensionsMm       String?
  plateWeightKgWithoutScrap          Float?
  plateScrapPct                      Float?
  plateWeightKgWithScrap             Float?
  plateSheetMetalDimensionsMm        String?
  plateCentrifugalImpellerRigCostPcs Float?
  plateLaserTimeMin                  Float?
  plateCasingCircumferenceM          Float?
  platePaintingLe                    Float?
  createdAt                          DateTime                 @default(now())
  updatedAt                          DateTime                 @updatedAt
  casing                             CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_impeller")
}

model CentrifugalCasingFunnels {
  id                               Int                      @id @default(autoincrement())
  casingId                         Int                      @unique
  funnel15mmWeightKgWithoutScrap   Float?
  funnel15mmScrapPct               Float?
  funnel15mmWeightKgWithScrap      Float?
  funnel15mmSheetMetalDimensionsMm String?
  funnel15mmDieCastingLePc         Float?
  funnel15mmFunnelMachiningLe      Float?
  funnel15mmGalvanizeLe            Float?
  funnel3mmWeightKgWithoutScrap    Float?
  funnel3mmScrapPct                Float?
  funnel3mmWeightKgWithScrap       Float?
  funnel3mmSheetMetalDimensionsMm  String?
  funnel3mmDieCastingLePc          Float?
  funnel3mmFunnelMachiningLe       Float?
  funnel3mmPaintingLe              Float?
  createdAt                        DateTime                 @default(now())
  updatedAt                        DateTime                 @updatedAt
  casing                           CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_funnels")
}

model CentrifugalCasingSleeveShaft {
  id                           Int                      @id @default(autoincrement())
  casingId                     Int                      @unique
  sleeveWeightKgWithoutScrap   Float?
  sleeveScrapPct               Float?
  sleeveWeightKgWithScrap      Float?
  sleeveSheetMetalDimensionsMm String?
  sleeveManufacturingLePc      Float?
  shaftWeightKgWithoutScrap    Float?
  shaftScrapPct                Float?
  shaftWeightKgWithScrap       Float?
  shaftSheetMetalDimensionsMm  String?
  shaftManufacturingLePc       Float?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt
  casing                       CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_sleeve_shaft")
}

model CentrifugalCasingMatchingFlange {
  id                              Int                      @id @default(autoincrement())
  casingId                        Int                      @unique
  flange3mmWeightKgWithoutScrap   Float?
  flange3mmScrapPct               Float?
  flange3mmWeightKgWithScrap      Float?
  flange3mmSheetMetalDimensionsMm String?
  flange3mmLaserTimeMin           Float?
  flange3mmRolling                Float?
  flange3mmCasingCircumferenceM   Float?
  selfAligningBearingHousingLe    Float?
  createdAt                       DateTime                 @default(now())
  updatedAt                       DateTime                 @updatedAt
  casing                          CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_matching_flange")
}

model CentrifugalCasingBearingAssembly {
  id                      Int                      @id @default(autoincrement())
  casingId                Int                      @unique
  boltsNutsKg             Float?
  assemblyLaboursPerShaft Float?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  casing                  CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_bearing_assembly")
}

model CentrifugalCasingFanBase {
  id                     Int                      @id @default(autoincrement())
  casingId               Int                      @unique
  weightKgWithoutScrap   Float?
  scrapPct               Float?
  weightKgWithScrap      Float?
  sheetMetalDimensionsMm String?
  laserTimeMin           Float?
  bendingLine            Float?
  paintingLe             Float?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  casing                 CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_fan_base")
}

model CentrifugalCasingBeltCover {
  id                     Int                      @id @default(autoincrement())
  casingId               Int                      @unique
  weightKgWithoutScrap   Float?
  scrapPct               Float?
  weightKgWithScrap      Float?
  sheetMetalDimensionsMm String?
  laserTimeMin           Float?
  casingCircumferenceM   Float?
  paintingLe             Float?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  casing                 CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_belt_cover")
}

model CentrifugalCasingMotorBase {
  id                     Int                      @id @default(autoincrement())
  casingId               Int                      @unique
  weightKgWithoutScrap   Float?
  scrapPct               Float?
  weightKgWithScrap      Float?
  sheetMetalDimensionsMm String?
  laserTimeMin           Float?
  bendingLine            Float?
  studNutPriceLe         Float?
  paintingLe             Float?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  casing                 CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_motor_base")
}

model CentrifugalCasingAccessories {
  id                       Int                      @id @default(autoincrement())
  casingId                 Int                      @unique
  vibrationIsolatorsLe     Float?
  vinylStickersLe          Float?
  namePlateLe              Float?
  packingLe                Float?
  labourCostLe             Float?
  internalTransportationLe Float?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  casing                   CentrifugalCasingPricing @relation(fields: [casingId], references: [id], onDelete: Cascade)

  @@map("centrifugal_casing_accessories")
}

model PulleyData {
  id            Int      @id @default(autoincrement())
  no            Int?
  beltType      String?
  grooves       Int?
  pitchDiameter Float?
  bushNo        String?
  minBore       Int?
  maxBore       Int?
  widthF        Float?
  condition     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("pulley_data")
}

model BeltLengthStandard {
  id        Int      @id @default(autoincrement())
  spz       Float?
  spa       Float?
  spb       Float?
  spc       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("belt_length_standard")
}

model PulleyStandard {
  id        Int      @id @default(autoincrement())
  no        Int?
  spz       Float?
  spa       Float?
  spb       Float?
  spc       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pulley_standard")
}
